# =============================================================================
# xPert Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
# All variables have sensible defaults; only set what you need to override.

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
XPERT_HOST=0.0.0.0
XPERT_PORT=8080

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Backend options: sqlite, postgres, file
XPERT_STORAGE_BACKEND=sqlite

# SQLite database path (used when XPERT_STORAGE_BACKEND=sqlite)
XPERT_DATA_PATH=./data/xpert.sqlite

# PostgreSQL connection string (used when XPERT_STORAGE_BACKEND=postgres)
# XPERT_STORAGE_DSN=postgres://user:password@localhost:5432/xpert?sslmode=disable

# -----------------------------------------------------------------------------
# Processing Configuration
# -----------------------------------------------------------------------------
# Maximum number of document sections to generate in parallel
XPERT_MAX_PARALLEL_SECTIONS=4

# Maximum retry attempts for failed jobs
XPERT_MAX_JOB_ATTEMPTS=2

# Default target word count for generated documents
XPERT_DEFAULT_WORD_COUNT=6000

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Provider options: mock, openai, openrouter, deepseek, ollama, custom
XPERT_LLM_PROVIDER=mock

# OpenAI-compatible API settings
XPERT_OPENAI_BASE_URL=https://api.openai.com/v1
XPERT_OPENAI_API_KEY=
XPERT_OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Model Pool Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable random model selection from a pool of models.
# When enabled, the system randomly selects a model for each LLM request.
# If a model fails, it automatically retries with another model from the pool.

# Feature flag to enable random model selection (default: false)
XPERT_ENABLE_RANDOM_MODEL_SELECTION=false

# Comma-separated list of models to use in the pool
# Example: gpt-4o,gpt-4o-mini,gpt-4-turbo
# Note: Only used when XPERT_ENABLE_RANDOM_MODEL_SELECTION=true
XPERT_AI_MODEL_POOL=

# -----------------------------------------------------------------------------
# Example Configurations
# -----------------------------------------------------------------------------

# --- Local Development (Mock Provider) ---
# XPERT_LLM_PROVIDER=mock

# --- OpenAI ---
# XPERT_LLM_PROVIDER=openai
# XPERT_OPENAI_API_KEY=sk-...
# XPERT_OPENAI_MODEL=gpt-4o-mini

# --- OpenAI with Model Pool ---
# XPERT_LLM_PROVIDER=openai
# XPERT_OPENAI_API_KEY=sk-...
# XPERT_ENABLE_RANDOM_MODEL_SELECTION=true
# XPERT_AI_MODEL_POOL=gpt-4o,gpt-4o-mini,gpt-4-turbo

# --- OpenRouter ---
# XPERT_LLM_PROVIDER=openrouter
# XPERT_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# XPERT_OPENAI_API_KEY=sk-or-...
# XPERT_OPENAI_MODEL=anthropic/claude-3-sonnet

# --- Local Ollama ---
# XPERT_LLM_PROVIDER=ollama
# XPERT_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# XPERT_OPENAI_MODEL=llama3
